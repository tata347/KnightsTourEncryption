<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" onDragDropped="#handleDragDropped" onDragOver="#handleDragOver" prefHeight="600.0" prefWidth="750.0" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.VaultDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="31.0" prefWidth="710.0">
            <children>
                <Label alignment="CENTER" prefHeight="18.0" prefWidth="78.0" text="Your Vault" textAlignment="CENTER" />
                <HBox alignment="CENTER" prefHeight="94.0" prefWidth="670.0">
                    <children>
                        <Button fx:id="exportButton" mnemonicParsing="false" onAction="#handleExport" prefHeight="45.0" prefWidth="100.0" text="Export" />
                        <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete" prefHeight="45.0" prefWidth="100.0" text="🗑 Delete">
                            <HBox.margin>
                                <Insets left="30.0" />
                            </HBox.margin>
                        </Button>
                        <Button fx:id="settingsButton" mnemonicParsing="false" onAction="#handleSettings" prefHeight="45.0" prefWidth="100.0" text="⚙ Settings">
                            <HBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <VBox fx:id="dropZone" alignment="CENTER" prefHeight="160.0" prefWidth="500.0" spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="DROP FILES HERE TO ENCRYPT" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="Password:" />
                        <PasswordField fx:id="passwordField" prefWidth="200.0" promptText="Enter encryption password" />
                        <PasswordField fx:id="confirmPasswordField" prefWidth="200.0" promptText="Confirm password" />
                    </children>
                </HBox>
                <Label fx:id="passwordErrorLabel" style="-fx-text-fill: red;" text="" />
            </children>
        </VBox>

        <ListView fx:id="fileListView" prefHeight="250.0" prefWidth="500.0" />
    </children>
</VBox>